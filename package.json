{
  "name": "racoon-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack の会話ログを蓄積し、@メンションで質問すると Claude が過去ログを根拠に回答する bot",
  "main": "dist/src/app.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env src/app.ts",
    "start": "node dist/src/app.js",
    "test": "vitest run",
    "backfill": "tsx --env-file=.env src/backfill.ts"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.125",
    "@libsql/client": "^0.15.0",
    "@slack/web-api": "^7.9.0",
    "@vercel/functions": "^2.0.0",
    "ai": "^6.0.197",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.30.1"
}
