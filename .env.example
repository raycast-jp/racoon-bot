# Slack (https://api.slack.com/apps → 対象 App)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# SQLite の保存先（ローカル開発時はデフォルトで ./data/slack-log.db）
# DB_PATH=./data/racoon-bot.db

# Cloud Run + Litestream 用（ローカルでは不要）
# REPLICA_URL=gcs://your-bucket/racoon-bot

# モデルの上書き（省略可）
# ANSWER_MODEL=claude-opus-4-8
# KEYWORD_MODEL=claude-haiku-4-5
